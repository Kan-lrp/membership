// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// Member 是我们自己的“会员主表”。
// Shopify 原生有 Customer，但会员积分余额、等级、权益这些属于我们 App 自己的业务数据。
model Member {
  // cuid() 会自动生成一个字符串 id，适合作为我们数据库内部主键。
  id         String   @id @default(cuid())
  // shop 用来区分不同店铺的数据。一个 App 可以被多个店铺安装，所以每张业务表都要带 shop。
  shop       String
  // Shopify customer id，同一个店铺下一个 customer 只能对应一个会员。
  customerId String
  // 下面这些字段是从 Shopify customer / order payload 里同步过来的基础展示信息。
  email      String?
  firstName  String?
  lastName   String?
  // 当前会员等级，指向 LevelConfig。
  // 这里允许为空，是为了兼容已经存在的老会员数据；页面展示时也会按累计积分临时计算。
  currentLevelId String?
  // createdAt / updatedAt 是常见的创建时间和更新时间。
  // @updatedAt 表示 Prisma 每次更新这条记录时会自动刷新时间。
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // 当前会员等级的关联数据。onDelete: SetNull 表示等级配置被删时，会员不会被删，只是等级清空。
  currentLevel LevelConfig? @relation(fields: [currentLevelId], references: [id], onDelete: SetNull)
  // 一个会员最多对应一个积分账户，所以这里是 PointsAccount?。
  // 问号表示可能还没有账户，比如后续先同步会员再发积分。
  pointsAccount PointsAccount?
  // 一个会员会有很多积分流水，所以这里是数组 PointsLedger[]。
  pointsLedgers PointsLedger[]

  // 防止同一个 Shopify customer 被同步成多个会员。
  // 组合唯一索引的意思是：shop + customerId 这一对值不能重复。
  @@unique([shop, customerId])
  // 给后台按邮箱搜索会员预留索引。
  @@index([shop, email])
  // 后续后台按等级筛选会员时会用到。
  @@index([shop, currentLevelId])
}

// PointsAccount 是积分账户表，保存“当前余额”和累计值。
// 它不是流水明细，只保存汇总状态。
model PointsAccount {
  id             String   @id @default(cuid())
  shop           String
  // 一个会员只有一个积分账户；这是会员账户层面的唯一约束。
  memberId       String   @unique
  // 当前可用积分余额。
  balance        Int      @default(0)
  // lifetimeEarned 是累计获得积分，用来做报表或等级判断。
  lifetimeEarned Int      @default(0)
  // lifetimeSpent 是累计消耗积分，MVP 还没做积分抵现，所以现在通常是 0。
  lifetimeSpent  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // @relation 表示 PointsAccount.memberId 指向 Member.id。
  // onDelete: Cascade 表示删除会员时，对应积分账户也会一起删除。
  member  Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  // 一个积分账户会有很多流水。
  ledgers PointsLedger[]

  // 查询时按店铺隔离账户；同时避免同一店铺同一会员重复建账户。
  @@unique([shop, memberId])
  // 给后台按余额排序/筛选预留索引。
  @@index([shop, balance])
}

// PointsLedger 是积分流水表。
// 每一次积分增加或扣减，都应该写一条流水，用于对账、排查和防重复。
model PointsLedger {
  id           String   @id @default(cuid())
  shop         String
  // memberId 和 accountId 同时保存，方便从会员或账户两个角度查流水。
  memberId     String
  accountId    String
  // type 表示流水类型，例如 EARN=获得积分，SPEND=消耗积分，ADJUST=人工调整。
  type         String
  // 本次变动的积分。获得积分为正数，扣减积分后续可以用负数或配合 type 表示。
  points       Int
  // 这笔流水写入后，账户的余额是多少。保存它可以方便对账。
  balanceAfter Int
  // reason 是给后台看的原因，例如 Order paid。
  reason       String?
  // sourceType + sourceId 描述这笔流水来自哪里，例如 ORDER_PAID + Shopify order id。
  sourceType   String
  sourceId     String
  // 暂时用 JSON 字符串保存一些附加信息，例如订单号、金额、customerId。
  // 后续字段稳定后，可以拆成单独列。
  metadataJson String?
  createdAt    DateTime @default(now())

  member  Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  account PointsAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  // 积分流水的幂等约束：同一个店铺、同一个业务来源、同一个来源 id 只能入账一次。
  // 例如 orders/paid webhook 重试多次，也只能为同一个 order id 创建一条 ORDER_PAID 流水。
  @@unique([shop, sourceType, sourceId])
  @@index([shop, createdAt])
  @@index([shop, memberId])
}

model RuleConfig {
  id                    String   @id @default(cuid())
  // MVP 阶段每个店铺只有一份积分规则。
  shop                  String   @unique
  // 每一个 currencyUnitCents 对应发多少积分。
  // 默认是 1，配合 currencyUnitCents=100，意思是每消费 1 元发 1 分。
  pointsPerCurrencyUnit Int      @default(1)
  // 货币单位用“分”保存。100 表示 1 元，避免用 0.01 这类小数参与计算。
  currencyUnitCents     Int      @default(100)
  // 商家可以临时关闭积分发放，关闭后订单 webhook 会记录为跳过，不发积分。
  isEnabled             Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// LevelConfig 是会员等级配置表。
// MVP 先自动创建四个默认等级：普通、银卡、金卡、黑金。
model LevelConfig {
  id              String   @id @default(cuid())
  shop            String
  // 等级名称，例如 普通会员、银卡会员。
  name            String
  // 达到多少累计积分后进入这个等级。
  thresholdPoints Int
  // sortOrder 用于页面展示排序，数字越小越靠前。
  sortOrder       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 这个等级下有哪些会员。
  members Member[]

  // 同一店铺内等级名称不能重复。
  @@unique([shop, name])
  // 同一店铺内同一个升级门槛只保留一个等级，避免两个等级同时命中。
  @@unique([shop, thresholdPoints])
  @@index([shop, sortOrder])
}

// WebhookEvent 是 webhook 事件表。
// 它不保存积分余额，只记录某个 webhook 事件处理到什么状态，方便防重复和排查异常。
model WebhookEvent {
  id               String    @id @default(cuid())
  shop             String
  // topic 是 Shopify webhook 类型，例如 orders/paid、app/uninstalled。
  topic            String
  // Shopify 资源 id，例如订单 id；和 topic 组合后用于识别一次业务事件。
  resourceId       String
  // Shopify 请求头里的 webhook id，主要用于日志排查。
  shopifyWebhookId String?
  // status 是我们自己的处理状态：PROCESSING / PROCESSED / SKIPPED / FAILED。
  status           String
  // attempts 记录这个事件尝试处理过几次，后续异常页面可以展示。
  attempts         Int       @default(0)
  // 失败或跳过原因，方便后台日志/异常处理页面展示。
  error            String?
  receivedAt       DateTime  @default(now())
  processedAt      DateTime?

  // webhook 事件的幂等约束：同一个店铺的同一个 topic + resourceId 只处理一次。
  // 这层记录处理状态，PointsLedger 的唯一约束再兜底防止积分重复入账。
  @@unique([shop, topic, resourceId])
  @@index([shop, status])
  @@index([shop, receivedAt])
}
